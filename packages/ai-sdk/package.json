{
  "name": "@agentface/ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK integration for AgentFace: use any AI SDK model with the assistant, or expose AgentFace actions as AI SDK tools",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentface/assistant": "workspace:*",
    "@agentface/core": "workspace:*",
    "@agentface/runtime": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^7.0.0"
  },
  "devDependencies": {
    "@agentface/eslint-config": "workspace:*",
    "@agentface/policy": "workspace:*",
    "@agentface/typescript-config": "workspace:*",
    "ai": "^7.0.0",
    "eslint": "^9.31.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-e-a-n-f/agent-face.git",
    "directory": "packages/ai-sdk"
  },
  "engines": {
    "node": ">=20"
  }
}
