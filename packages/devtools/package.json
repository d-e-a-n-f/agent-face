{
  "name": "@agentface/devtools",
  "version": "0.1.0",
  "description": "Embeddable AgentFace development panel",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentface/core": "workspace:*",
    "@agentface/react": "workspace:*",
    "@agentface/runtime": "workspace:*"
  },
  "devDependencies": {
    "@agentface/eslint-config": "workspace:*",
    "@agentface/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.31.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d-e-a-n-f/agent-face.git",
    "directory": "packages/devtools"
  },
  "engines": {
    "node": ">=20"
  }
}
