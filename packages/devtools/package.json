{
  "name": "@agentface/devtools",
  "version": "0.1.0",
  "description": "Embeddable AgentFace development panel",
  "license": "MIT",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentface/core": "workspace:*",
    "@agentface/runtime": "workspace:*",
    "@agentface/react": "workspace:*"
  },
  "devDependencies": {
    "@agentface/eslint-config": "workspace:*",
    "@agentface/typescript-config": "workspace:*",
    "eslint": "^9.31.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
